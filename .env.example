# ---------------------------------------------------------------------------
# Tendari configuration. Copy to .env and fill in. All values have safe
# defaults for local docker-compose; secrets are optional in build/demo mode.
# ---------------------------------------------------------------------------

# --- infra ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/tendari
REDIS_URL=redis://redis:6379/0

# --- LLM provider (swappable) ---
LLM_PROVIDER=anthropic            # anthropic | openai | mock
ANTHROPIC_API_KEY=                # required when LLM_PROVIDER=anthropic
OPENAI_API_KEY=                   # required for OpenAI chat AND for real embeddings
CHAT_MODEL=claude-haiku-4-5       # set to your chosen current chat model id

# --- embeddings ---
# Anthropic has no embeddings API; embeddings always use OpenAI when a key is
# present, otherwise a deterministic offline fallback (lower quality, no key).
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536                # MUST match EMBEDDING_MODEL and the DB migration

# --- agent engine ---
MAX_AGENT_ITERATIONS=8            # hard cap → no runaway tool loops / spend
CONTEXT_TOKEN_BUDGET=12000        # truncate oldest history beyond this before a call
RETRIEVAL_TOP_K=5                 # chunks returned by search_help_docs

# --- RAG chunking (owned decision: ~800 tokens, 100 overlap) ---
CHUNK_TARGET_TOKENS=800
CHUNK_OVERLAP_TOKENS=100

# --- external side-effecting services (optional in build/demo mode) ---
SENDGRID_API_KEY=                 # if empty, emails are logged instead of sent
SENDGRID_FROM_EMAIL=support@tendari.example
STRIPE_SECRET_KEY=                # test-mode key (sk_test_...); refunds simulated if empty

# --- demo seed ---
# Raw key for the seeded demo workspace (only the SHA-256 hash is stored).
# This default is low-entropy and intended for LOCAL demo only — OVERRIDE it
# with a high-entropy value (e.g. output of `python -c "from app.security import
# generate_api_key as g; print(g())"`) before any public/shared deploy.
SEED_API_KEY=demo-key-tendari-001
SEED_WORKSPACE_NAME=Acme Outdoors

# --- pricing override (optional) ---
# JSON map {model: {input_per_1k, output_per_1k}} in USD; overrides built-in
# defaults in app/observability/usage.py. Treat token prices as config.
# LLM_PRICING_JSON={"claude-haiku-4-5":{"input_per_1k":0.001,"output_per_1k":0.005}}
LLM_PRICING_JSON=
